# Shopify (backend + checkout)
# Get Storefront API token: Shopify Admin -> Settings -> Apps and sales channels -> Develop apps -> Create -> Configure Storefront API scopes
# Recommended scopes:
# - unauthenticated_read_product_listings
# - unauthenticated_read_product_inventory
# - cart access supported by the Storefront API for checkout flows
# - unauthenticated_write_customers (required for preorder email signup)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Optional: for GitHub Pages deploy (use your repo name, e.g. /grab-a-gem/)
# VITE_BASE_PATH=/
